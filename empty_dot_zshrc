# --- Env vars --- #
export EDITOR="nvim"
# Used by gh dash extension
export GH_DASH_CONFIG="$HOME/.config/gh-dash.yaml"

source "${HOME}/.zshenv"

alias v="nvim"
alias gst="git status"
alias ll="lsd -al"
alias k="kubectl"

# --- pnpm --- #
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- ghcup --- #
export PATH="$HOME/.ghcup/bin:$PATH"

# -- go -- #
export PATH="$PATH:$HOME/go/bin"

# -- rustup -- #
export PATH="$PATH:$(brew --prefix)/opt/rustup/bin"

# -- Rancher Desktop -- #
export PATH="$PATH:$HOME/.rd/bin"

# Herd injected PHP 8.4 configuration.
export HERD_PHP_84_INI_SCAN_DIR="$HOME/Library/Application Support/Herd/config/php/84/"

# Herd injected PHP binary.
export PATH="$HOME/Library/Application Support/Herd/bin/:$PATH"

# Python
export PATH="$HOME/.local/bin:$PATH"

set -o vi # Use vim keybindings

# --- History --- #
HISTFILE=$HOME/.history
HISTSIZE=10000000
SAVEHIST=10000000

setopt HIST_IGNORE_SPACE # Don't save command to history when prefixed by a space
setopt HIST_IGNORE_DUPS # Share history between sessions

# Search history with up and down keys
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search # Up
bindkey "^[[B" down-line-or-beginning-search # Down

# ------------ Completions --------------
fpath+=("$(brew --prefix)/share/zsh/site-functions")
if [ ! -d ~/.zfunc ]; then
  mkdir -p ~/.zfunc
fi

source <(fzf --zsh)

fpath+=~/.zfunc

if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
fi

autoload -Uz compinit
compinit -u

zstyle ':completion:*' menu select

# --- Shell plugins --- #
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# --- Kubectl completions --- #
source <(kubectl completion zsh)

# --- Vega CLI --- #
source "${HOME}/vega/env"

# --- direnv shell ingeration --- #
eval "$(direnv hook zsh)"

# --- worktrunk shell integration --- #
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# Load pure prompt --- #
autoload -U promptinit; promptinit
prompt pure
